# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Streamlit
.streamlit/config.toml
.streamlit/secrets.toml

# IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
.superpowers/

superpowers-main/
ui-ux-pro-max-skill-main
# loose source video (copied into landing/public/media)
/Holographic_*.mp4

# Trained model binaries: pure output of `python -m src.train`, regenerable from
# source + data. Keep metrics.json and frontend_data.json tracked (small,
# meaningful diffs); the frontend consumes the JSON snapshot, never the .joblib.
# To pin a final checkpoint near submission: `git add -f models/*.joblib`.
models/*.joblib

# Raw real datasets (Backblaze ~12 GB, AI4I, C-MAPSS). Downloaded locally and
# fed through src/data_loaders.py; never committed. data/ (generated CSVs) is
# likewise untracked.
realdata/
# Generated training CSVs (incl. ~1.5 GB data/storage.csv). The comment above
# already documents these as untracked; this is the actual rule.
data/

# Node deps anywhere (dashboard/ runner, landing/ — landing also has its own).
node_modules/

# Local app runner / preview scaffolding — NOT a deliverable, regenerable. The
# dashboard/ Vite project only hosts the frontend account's frontend/App.jsx with
# the committed frontend_data.json snapshot injected; .claude/launch.json is the
# local preview-server config. The real dashboard source lives in frontend/App.jsx.
dashboard/
.claude/launch.json
